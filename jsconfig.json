{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@components/*": ["./src/components/*"],
      "@components/common/*": ["./src/components/common/*"],
      "@components/dashboard/*": ["./src/components/dashboard/*"],
      "@components/layout/*": ["./src/components/layout/*"],
      "@components/tasks/*": ["./src/components/tasks/*"],
      "@components/forms/*": ["./src/components/forms/*"],
      "@components/ui/*": ["./src/components/ui/*"],
      "@components/charts/*": ["./src/components/charts/*"],
      "@pages/*": ["./src/pages/*"],
      "@pages/auth/*": ["./src/pages/auth/*"],
      "@pages/dashboard/*": ["./src/pages/dashboard/*"],
      "@pages/admin/*": ["./src/pages/admin/*"],
      "@pages/tasks/*": ["./src/pages/tasks/*"],
      "@pages/settings/*": ["./src/pages/settings/*"],
      "@pages/profile/*": ["./src/pages/profile/*"],
      "@utils/*": ["./src/utils/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@store/*": ["./src/store/*"],
      "@services/*": ["./src/services/*"],
      "@constants/*": ["./src/constants/*"],
      "@styles/*": ["./src/styles/*"],
      "@assets/*": ["./src/assets/*"],
      "@data/*": ["./src/data/*"],
      "@mock/*": ["./src/mock/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@routes/*": ["./src/routes/*"]
    },
    "jsx": "react-jsx",
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src/**/*",
    "src/**/*.jsx",
    "src/**/*.js",
    "src/**/*.json",
    "src/**/*.css",
    "vite.config.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "coverage",
    ".git",
    ".vscode",
    "public"
  ]
}